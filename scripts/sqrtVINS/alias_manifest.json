    "video_rate_hz": 30,
    "gyro_scale_rad_s_per_count": 0.000266316,
    "accel_scale_m_s2_per_count": 0.001197101,
    "use_mp4_comment_start_time": true,
    "use_frame_pts_when_available": true,
    "crop_to_global_sensor_intersection": true,
    "sqrtvins_args": {
      "bag_start": 5.0,
      "win_time": 1.0,
      "do_bg": true,
